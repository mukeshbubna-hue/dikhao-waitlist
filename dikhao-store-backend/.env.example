PORT=3001

# Supabase → project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# GCP: project dikhao-prod, Vertex AI + Cloud Storage APIs enabled,
# service account dikhao-vertex-sa (Vertex AI User role), JSON key downloaded
GCP_PROJECT_ID=
GCP_LOCATION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GCS_STAGING_BUCKET=dikhao-vertex-staging

# photoroom.com/api → Settings → API Keys (500 free/month)
PHOTOROOM_API_KEY=

# dashboard.razorpay.com → Settings → API Keys (TEST in dev)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

FRONTEND_URL=http://localhost:5173
NODE_ENV=development
MOCK_OTP=true

# Leave blank until Gupshup is live.
GUPSHUP_API_KEY=
GUPSHUP_SOURCE_NUMBER=
